# Runtime
DEXTER_RUNTIME_MODE=read_only
DEXTER_NETWORK=devnet
DEXTER_ALLOW_MAINNET_LIVE=false
DEXTER_MAINNET_DRY_RUN=true
DEXTER_EMERGENCY_STOP_FILE=./dev/EMERGENCY_STOP
DEXTER_CLOSE_POSITIONS_ON_SHUTDOWN=false

# Solana RPC:
# - devnet ignores HTTP_URL / WS_URL and uses Dexter's fixed devnet endpoints
# - mainnet reads HTTP_URL / WS_URL from this file
HTTP_URL=https://api.mainnet-beta.solana.com
WS_URL=wss://api.mainnet-beta.solana.com
PRIVATE_KEY=

# Dexter database
DATABASE_URL=postgres://dexter_user:replace-me@127.0.0.1:5432/dexter_db
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=dexter_db
DB_USER=dexter_user
DB_PASSWORD=replace-me

# PostgreSQL bootstrap admin connection for `database.py`.
# `dexter database-setup` on Windows fills these in automatically and rewrites them
# if Dexter is managing its own local PostgreSQL cluster.
POSTGRES_ADMIN_DSN=postgres://postgres:replace-me@127.0.0.1:5432/postgres
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=replace-me
POSTGRES_ADMIN_HOST=127.0.0.1
POSTGRES_ADMIN_PORT=5432
POSTGRES_ADMIN_DB=postgres

# Windows managed PostgreSQL markers.
# `dexter database-setup` appends and maintains these when Dexter owns the local cluster.
# DEXTER_LOCAL_POSTGRES_MANAGED=true
# DEXTER_LOCAL_POSTGRES_BIN_DIR=C:\Program Files\PostgreSQL\17\bin
# DEXTER_LOCAL_POSTGRES_DATA_DIR=.\.dexter\postgres\17\data
# DEXTER_LOCAL_POSTGRES_LOG_FILE=.\.dexter\postgres\17\postgres.log
# DEXTER_LOCAL_POSTGRES_PORT=55432

# Pools and storage
DEXTER_DB_MIN_POOL_SIZE=1
DEXTER_DB_MAX_POOL_SIZE=20
DEXTER_LOG_DIR=./dev/logs
DEXTER_RESULTS_FILE=./dev/results.txt
DEXTER_LEADERBOARD_FILE=./dev/leaderboard.txt
DEXTER_BACKUP_ENABLED=true
DEXTER_BACKUP_DIR=../dexter_backups
DEXTER_BACKUP_INTERVAL_SECONDS=3600
DEXTER_BACKUP_RETENTION_COUNT=24
DEXTER_PG_DUMP_PATH=pg_dump
DEXTER_SOL_PRICE_CACHE_TTL_SECONDS=300
DEXTER_SOL_PRICE_REQUEST_TIMEOUT_SECONDS=4
DEXTER_SOL_PRICE_FAILURE_LOG_COOLDOWN_SECONDS=300
DEXTER_SOL_PRICE_FALLBACK_USD=210.11

# Research data powers the normalized replay/export/dashboard layer.
# Set this to false only if you want the legacy runtime without the extra research tables.
DEXTER_DATASTORE_ENABLED=true
DEXTER_DATASTORE_RAW_EVENT_RETENTION_DAYS=30
DEXTER_DATASTORE_EXPORT_DIR=./dev/exports

# Risk controls
DEXTER_PER_TRADE_SOL_CAP=100.00
DEXTER_SESSION_SOL_CAP=1000.00
# Gross spend cap for the whole UTC day across all entries.
DEXTER_DAILY_SOL_CAP=10000.00
DEXTER_MAX_CONCURRENT_SESSIONS=100
DEXTER_PER_CREATOR_MAX_SESSIONS=100
DEXTER_WALLET_RESERVE_FLOOR_SOL=0.00020398
# Realized-loss stop for the UTC day. This is different from DEXTER_DAILY_SOL_CAP:
# it stops new entries after enough closed-trade losses, even if spend is still below the cap.
DEXTER_DAILY_DRAWDOWN_STOP_SOL=10000.00

# Strategy and execution policy
DEXTER_STRATEGY_PROFILE=balanced
# DEXTER_MIN_ENTRY_SCORE_OVERRIDE=0.60
DEXTER_QUOTE_RETRY_LIMIT=3
DEXTER_SEND_RETRY_LIMIT=2
DEXTER_CONFIRMATION_RETRY_LIMIT=6
DEXTER_RETRY_DELAY_SECONDS=0.25

# Mainnet-only MEV sender routing for live buy/sell submissions.
# Dexter ignores USE_MEV on devnet to avoid sender errors there.
USE_MEV=false
MEV_PROVIDER=jito
MEV_TIP=0.00001
MEV_JITO_KEY=
MEV_NEXTBLOCK_KEY=
MEV_ZERO_SLOT_KEY=
MEV_TEMPORAL_KEY=
MEV_BLOXROUTE_KEY=

# Legacy trust-factor and trading knobs used by Dexter's strategy runtime.
# These now live in .env so the TUI can edit them directly.
TOTAL_SWAPS_ABOVE_2_MINTS=1
TOTAL_SWAPS_1_MINT=1
MEDIAN_PEAK_MC_ABOVE_2_MINTS=1
MEDIAN_PEAK_MC_1_MINT=1
HIGHEST_PRICE_MIN_SWAPS=1
SNIPE_PRICE_TO_PEAK_PRICE_RATIO=1.0
TRUST_FACTOR_RATIO=0.0
SNIPING_PRICE_TIME=0.0
AMOUNT_BUY_TL_2=0.01
AMOUNT_BUY_TL_1=0.01
SLIPPAGE_AMOUNT=1.30
FEE_LEVEL=medium
MAX_FEE=0.00005
PRICE_STEP_UNITS=40
PROFIT_MARGIN=0.8
PRICE_TREND_WEIGHT=0.4
TX_MOMENTUM_WEIGHT=0.6
INCREMENT_THRESHOLD=25
INCREMENT_COOLDOWN=15.0
DECREMENT_THRESHOLD=20
DROP_TIME=30
STAGNANT_UNDER_PRICE=13
LEADERBOARD_UPDATE_INTERVAL=10

# Wallet roles
# PRIVATE_KEY is the default signer for Dexter.
# DEXTER_TRADING_PRIVATE_KEY lets you override that signer explicitly.
# DEXTER_HOT_PRIVATE_KEY is currently informational for snapshots / future multi-wallet flows.
# DEXTER_TREASURY_ADDRESS is an informational reporting label, not an execution key.
DEXTER_TRADING_PRIVATE_KEY=
DEXTER_HOT_PRIVATE_KEY=
DEXTER_TREASURY_ADDRESS=

# Operator state and controls
DEXTER_STATE_DIR=./dev/state
DEXTER_TRADER_SNAPSHOT_FILE=./dev/state/trader-runtime.json
DEXTER_COLLECTOR_SNAPSHOT_FILE=./dev/state/collector-runtime.json
DEXTER_OPERATOR_CONTROL_FILE=./dev/state/operator-control.json

# Alerts
DEXTER_TELEGRAM_BOT_TOKEN=
# Leave blank and message the bot /id while Dexter is running to auto-fill this.
DEXTER_TELEGRAM_CHAT_ID=
DEXTER_DISCORD_WEBHOOK_URL=
DEXTER_DESKTOP_NOTIFICATIONS=true
